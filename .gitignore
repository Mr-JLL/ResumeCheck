# === 敏感信息（绝对不能提交）===
.env
*.env
.env.*

# === Python 自动生成的缓存 ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === 工作区数据（每天扫描的简历，会越来越大）===
工作区_*/

# === 简历数据库与原始文件 ===
data/

# === 招聘统计表（含求职者信息）===
*.xlsx
*.xls

# === 校准题库相关（PDF/HTML 太大，不适合 git）===
校准题库_PDF/
校准题库_负样本_HTML/
校准题库_文本/

# === 二进制大文件 ===
msedgedriver.exe
*.exe

# === Excel 临时文件 ===
~$*.xlsx
~$*.xls

# === 日志文件 ===
*.log

# === 历史评估报告（运行时生成）===
评估报告_v*.xlsx
历史评估报告/

# === 操作系统生成的文件 ===
.DS_Store
Thumbs.db

# === IDE 配置 ===
.vscode/
.idea/

# === Claude Code 本地配置 ===
.claude/

# === 截图 ===
*.png
*.jpg
*.jpeg